{
  "expo": {
    "name": "NGSK",
    "slug": "NGSK-app",
    "version": "10.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/new-logo-ios.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "bundleIdentifier": "com.ngsk.NGSKapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["audio"]   
      }
    },
    "android": {
      "icon": "./assets/images/new-logo.png",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "www.youtube.com"
            },
            {
              "scheme": "https",
              "host": "youtube.com"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/new-logo-transp.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.ngsk.NGSKapp",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS"  
      ],
      "foregroundService": {
        "type": "mediaPlayback",
        "notificationChannelName": "Playback"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon-transparent.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b28cb3bc-c891-449c-9a93-c870cec2838a"
      }
    },
    "owner": "ngsk",

    "runtimeVersion": "8.0.0",
    "updates": {
      "url": "https://u.expo.dev/b28cb3bc-c891-449c-9a93-c870cec2838a"
    }
  }
}
